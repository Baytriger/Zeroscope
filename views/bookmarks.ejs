<%- include('partials/header') %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 py-8" style="position:relative;z-index:1;">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
      <h1 style="font-family:'Syne',sans-serif;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:800;color:var(--text);">
        🔖 My Bookmarks
      </h1>
      <p style="font-size:1rem;color:var(--text-muted);margin-top:4px;">Track your saved opportunities and update their status.</p>
    </div>
    <a href="/" class="btn-outline self-start sm:self-auto flex items-center gap-2">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
      Browse More
    </a>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
    <div class="stat-card">
      <div class="stat-value"><%= analytics.total %></div>
      <div class="stat-label">Total</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color:var(--success);"><%= analytics.active %></div>
      <div class="stat-label">Active</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color:var(--accent);"><%= analytics.applied %></div>
      <div class="stat-label">Applied</div>
    </div>
    <div class="stat-card">
      <div class="stat-value" style="color:#FFD700;"><%= analytics.won %></div>
      <div class="stat-label">Won 🏆</div>
    </div>
  </div>

  <!-- Filters -->
  <div class="flex flex-col sm:flex-row gap-3 mb-6">
    <div class="flex gap-2 overflow-x-auto" style="scrollbar-width:none;">
      <% ['all','active','applied','won','expired'].forEach(function(s) { %>
      <a href="/bookmarks?status=<%= s %>&category=<%= currentCategory %>"
        class="filter-tab flex-shrink-0 <%= s === currentStatus ? 'active' : '' %>">
        <%= s.charAt(0).toUpperCase() + s.slice(1) %>
      </a>
      <% }) %>
    </div>
    <div class="flex gap-2 overflow-x-auto sm:ml-auto" style="scrollbar-width:none;">
      <% ['all','bounty','grant','job','event'].forEach(function(cat) { %>
      <a href="/bookmarks?status=<%= currentStatus %>&category=<%= cat %>"
        class="filter-tab flex-shrink-0 <%= cat === currentCategory ? 'active' : '' %>">
        <%= cat === 'all' ? 'All Types' : cat.charAt(0).toUpperCase() + cat.slice(1) %>
      </a>
      <% }) %>
    </div>
  </div>

  <!-- Bookmarks List -->
  <% if (bookmarks && bookmarks.length > 0) { %>
  <div class="flex flex-col gap-4">
    <% bookmarks.forEach(function(bm, i) { %>
    <%
      const dl = bm.deadline ? new Date(bm.deadline) : null;
      const now = new Date();
      const isExp = dl && dl < now;
      const daysLeft = dl ? Math.ceil((dl - now) / 86400000) : null;
    %>
    <div class="card p-5 fade-in" style="animation-delay:<%= i * 50 %>ms;">
      <div class="flex flex-col sm:flex-row sm:items-start gap-4">
        <!-- Left content -->
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-center gap-2 mb-2">
            <span class="badge badge-<%= bm.category %>">
              <%= bm.category === 'bounty' ? '🎯' : bm.category === 'grant' ? '💰' : bm.category === 'job' ? '💼' : '🎪' %>
              <%= bm.category %>
            </span>
            <span class="badge" style="background:var(--bg-card2);color:var(--text-dim);border:1px solid var(--border);">
              <%= bm.source %>
            </span>
            <% if (bm.status === 'won') { %>
            <span class="badge" style="background:rgba(255,215,0,0.12);color:#FFD700;border:1px solid rgba(255,215,0,0.3);">🏆 Won</span>
            <% } else if (bm.status === 'applied') { %>
            <span class="badge" style="background:rgba(139,92,246,0.12);color:#8b5cf6;border:1px solid rgba(139,92,246,0.3);">📤 Applied</span>
            <% } else if (isExp) { %>
            <span class="badge" style="background:rgba(239,68,68,0.12);color:#ef4444;border:1px solid rgba(239,68,68,0.3);">⚠️ Expired</span>
            <% } else { %>
            <span class="badge" style="background:rgba(16,185,129,0.12);color:#10b981;border:1px solid rgba(16,185,129,0.3);">● Active</span>
            <% } %>
          </div>

          <h3 style="font-family:'Syne',sans-serif;font-weight:700;font-size:1.05rem;color:var(--text);line-height:1.3;margin-bottom:6px;">
            <% if (bm.sourceUrl) { %>
            <a href="<%= bm.sourceUrl %>" target="_blank" rel="noopener noreferrer" style="color:var(--text);text-decoration:none;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text)'">
              <%= bm.title %> <span style="font-size:0.75rem;color:var(--accent);">↗</span>
            </a>
            <% } else { %>
            <%= bm.title %>
            <% } %>
          </h3>

          <% if (bm.description) { %>
          <p style="font-size:0.875rem;color:var(--text-muted);line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
            <%= bm.description %>
          </p>
          <% } %>

          <div class="flex flex-wrap items-center gap-4 mt-3">
            <div>
              <span style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem;color:var(--accent);">
                <%= isNaN(parseFloat(bm.reward)) ? bm.reward : '$' + parseFloat(bm.reward).toLocaleString() %>
              </span>
              <span style="font-size:0.75rem;color:var(--text-muted);margin-left:4px;"><%= bm.rewardToken %></span>
            </div>
            <% if (dl && !isExp) { %>
            <span data-deadline="<%= bm.deadline %>" class="countdown"></span>
            <% } else if (isExp) { %>
            <span style="font-size:0.8rem;color:var(--danger);font-weight:600;">⚠️ Deadline passed</span>
            <% } else { %>
            <span style="font-size:0.8rem;color:var(--success);font-weight:600;">No deadline</span>
            <% } %>
            <span style="font-size:0.75rem;color:var(--text-dim);">Saved <%= new Date(bm.savedAt).toLocaleDateString() %></span>
          </div>
        </div>

        <!-- Right actions -->
        <div class="flex flex-row sm:flex-col items-center sm:items-end gap-2 flex-shrink-0">
          <!-- Status selector -->
          <select
            class="zs-select text-sm"
            style="font-size:0.8rem;padding:6px 10px;"
            onchange="updateStatus('<%= bm._id %>', this.value)">
            <option value="active"  <%= bm.status === 'active'  ? 'selected' : '' %>>Active</option>
            <option value="applied" <%= bm.status === 'applied' ? 'selected' : '' %>>Applied</option>
            <option value="won"     <%= bm.status === 'won'     ? 'selected' : '' %>>Won 🏆</option>
            <option value="expired" <%= bm.status === 'expired' ? 'selected' : '' %>>Expired</option>
          </select>

          <% if (bm.sourceUrl) { %>
          <a href="<%= bm.sourceUrl %>" target="_blank" rel="noopener noreferrer" class="btn-outline" style="padding:6px 14px;font-size:0.8rem;">
            Open →
          </a>
          <% } %>

          <!-- Delete -->
          <form action="/bookmarks/<%= bm._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Remove this bookmark?')">
            <button type="submit" style="padding:6px 12px;border-radius:8px;background:rgba(239,68,68,0.1);color:#ef4444;border:1px solid rgba(239,68,68,0.3);font-size:0.8rem;font-family:'Syne',sans-serif;font-weight:600;cursor:pointer;" onmouseover="this.style.background='rgba(239,68,68,0.2)'" onmouseout="this.style.background='rgba(239,68,68,0.1)'">
              Remove
            </button>
          </form>
        </div>
      </div>
    </div>
    <% }) %>
  </div>

  <% } else { %>
  <div class="text-center py-20">
    <div style="font-size:4rem;margin-bottom:16px;">🔖</div>
    <h3 style="font-family:'Syne',sans-serif;font-size:1.3rem;font-weight:700;color:var(--text);margin-bottom:8px;">No bookmarks yet</h3>
    <p style="color:var(--text-muted);margin-bottom:20px;">Save bounties, grants, and jobs to track them here.</p>
    <a href="/" class="btn-accent inline-block">Browse Opportunities</a>
  </div>
  <% } %>

</main>

<script>
async function updateStatus(bookmarkId, status) {
  try {
    const res = await fetch(`/bookmarks/${bookmarkId}/status`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status }),
    });
    const data = await res.json();
    if (data.success) {
      if (status === 'won') showToast('🏆 Marked as Won! +100 XP', 'success');
      else showToast('Status updated!', 'success');
      setTimeout(() => location.reload(), 1000);
    }
  } catch { showToast('Update failed', 'error'); }
}
</script>

<%- include('partials/footer') %>
