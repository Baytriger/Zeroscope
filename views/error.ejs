<%- include('partials/header') %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 py-8" style="position:relative;z-index:1;">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <div style="font-size:5rem;margin-bottom:16px;"><%= code === 404 ? '🌌' : '⚠️' %></div>
    <h1 style="font-family:'Syne',sans-serif;font-size:4rem;font-weight:800;color:var(--accent);line-height:1;"><%= code || 500 %></h1>
    <h2 style="font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:700;color:var(--text);margin:12px 0 8px;">
      <%= code === 404 ? 'Page Not Found' : 'Server Error' %>
    </h2>
    <p style="color:var(--text-muted);max-width:400px;margin-bottom:28px;"><%= message %></p>
    <a href="/" class="btn-accent">← Back to Dashboard</a>
  </div>
</main>

<%- include('partials/footer') %>
